# Example environment variables for backend
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/portfolio
CLIENT_URLS=http://localhost:5173,http://localhost:3000

# SMTP settings (optional if using SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-or-quoted-if-containing-#
SMTP_FROM=your-email@gmail.com
CONTACT_RECEIVER_EMAIL=your-email@gmail.com

# Or use SendGrid instead of SMTP
# SENDGRID_API_KEY=your_sendgrid_api_key

# Disable sending emails in development
# MAIL_DISABLED=true
